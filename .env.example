# 云筑天瞳 V8 环境变量示例
YZT_SECRET_KEY=please-change-this-secret-key
DEEPSEEK_API_KEY=

# 真实YOLO模型配置
# 1. 推荐把训练好的模型放到 models/site_safety.pt
# 2. 裂缝模型放到 models/crack_detection.pt
YOLO_SITE_MODEL=models/site_safety.pt
YOLO_CRACK_MODEL=models/crack_detection.pt

# 是否启用真实YOLO
# auto = 如果安装 ultralytics 且模型存在则启用，否则回退到视觉规则分析
# force = 强制使用YOLO，模型不存在会报错
# off = 关闭YOLO
YOLO_MODE=auto
